{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/directory", "destination": "/directory.html" },
    { "source": "/events", "destination": "/events.html" },
    { "source": "/markplaats", "destination": "/markplaats.html" },
    { "source": "/markplaats-post", "destination": "/markplaats-post.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
